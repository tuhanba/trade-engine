# AX — Örnek .env Dosyası
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun
# cp .env.example .env

# ─── TEMEL MOD ────────────────────────────────
AX_MODE=execute
EXECUTION_MODE=paper

# ─── BİNANCE ──────────────────────────────────
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
BINANCE_TESTNET=false

# ─── TELEGRAM ─────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ─── N8N ──────────────────────────────────────
N8N_BASE_URL=http://localhost:5678
N8N_SECRET=aurvex-ax-secret

# ─── RİSK ─────────────────────────────────────
RISK_PCT=1.0
MAX_OPEN_TRADES=2
DAILY_MAX_LOSS_PCT=3.0
CIRCUIT_BREAKER_LOSSES=3
CIRCUIT_BREAKER_MINUTES=120

# ─── SİNYAL FİLTRE ────────────────────────────
MIN_RR=1.5
MIN_EXPECTED_MFE_R=1.0
MIN_VOLUME_M=10.0
MIN_CHANGE_PCT=1.5

# ─── SL / TP ──────────────────────────────────
SL_ATR_MULT=1.3
TP1_R=0.9
TP1_CLOSE_PCT=40
TP2_R=1.5
TP2_CLOSE_PCT=30
RUNNER_CLOSE_PCT=30
TRAIL_ATR_MULT=1.0

# ─── PAPER ────────────────────────────────────
PAPER_BALANCE_START=250.0
PAPER_FEE_RATE=0.0004
PAPER_SLIPPAGE=0.0002

# ─── DASHBOARD ────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5000
