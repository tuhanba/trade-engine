# ── AX Trade Engine .env Template ──
# Tüm token/key değerleri SADECE buradan okunur.
# Bu dosyayı .gitignore'a ekleyin!

# Binance API
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Mod
EXECUTION_MODE=paper
LIVE_TRADING_ENABLED=False
DRY_RUN=True

# Risk
RISK_PCT=1.0
MAX_OPEN_TRADES=5
DAILY_MAX_LOSS_PCT=5.0
MAX_LEVERAGE=20
MAX_MARGIN_LOSS_PCT=0.40
DEFAULT_FEE_RATE=0.0004

# TP Splits
TP1_CLOSE_PCT=40
TP2_CLOSE_PCT=30
RUNNER_CLOSE_PCT=30

# Trailing
TRAIL_ATR_MULT=1.5
BREAKEVEN_ENABLED=True
BREAKEVEN_OFFSET_PCT=0.05

# Paper
INITIAL_PAPER_BALANCE=250.0
MAX_HOLD_MINUTES=240

# Dashboard
SECRET_KEY=ax_secret_change_me
DASHBOARD_PORT=5000

# Network / Proxy (Türkiye'den Binance erişimi engellenmiş ise)
# HTTPS_PROXY=socks5://127.0.0.1:1080
# BINANCE_TESTNET=False
# BINANCE_TLD=com

# Scanner
SCAN_INTERVAL=60
MIN_VOLUME_USD=5000000
AX_MODE=execute
