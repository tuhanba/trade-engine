# ─────────────────────────────────────────────────────────────────────
# AX Trade Engine — Ortam Değişkenleri ŞABLONU
# Kullanım:  cp .env.example .env   →  ardından değerleri doldurun.
# Gizli anahtarları ASLA commit etmeyin (.env .gitignore ile yoksayılır).
# Buradakiler en sık kullanılan değişkenler; tüm gelişmiş parametreler
# için config.py'ye bakın.
# ─────────────────────────────────────────────────────────────────────

# ── Çalışma modu / güvenlik (varsayılan: paper, canlı KAPALI) ──
EXECUTION_MODE=paper
AX_MODE=paper
CONFIRMATION_MODE=False
CONFIRM_LIVE_TRADING=False
DRY_RUN=False

# ── Binance API ──
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Telegram bildirimleri ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Friday CEO / LLM  (FRIDAY_LLM_PROVIDER: anthropic | gemini) ──
FRIDAY_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Dashboard (Flask) ──
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
DASHBOARD_PIN=
ALLOWED_IPS=

# ── Redis (opsiyonel hot-state cache; testlerde kapalıdır) ──
REDIS_ENABLED=False
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── Depolama / loglar ──
DB_PATH=trading.db
LOG_DIR=logs
