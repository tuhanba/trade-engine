# ── AX Trade Engine .env Template ──
# Tüm token/key değerleri SADECE buradan okunur.
# Bu dosyayı .gitignore'a ekleyin!

# ── Güvenlik ayarları ──
EXECUTION_MODE=paper
LIVE_TRADING_ENABLED=False
DRY_RUN=True
CONFIRM_LIVE_TRADING=False
USE_BINANCE_PRIVATE_API=False

# ── Binance API (sadece public data için) ──
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Telegram ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── DB ──
DB_PATH=trading.db

# ── Risk ──
RISK_PCT=1.0
MAX_OPEN_TRADES=5
DAILY_MAX_LOSS_PCT=5.0
MAX_LEVERAGE=20
DEFAULT_FEE_RATE=0.0004

# ── Scanner ──
SCAN_INTERVAL_SECONDS=60
MIN_VOLUME_USDT=5000000
MIN_MOVE_PCT=0.5

# ── Dashboard / Flask ──
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
