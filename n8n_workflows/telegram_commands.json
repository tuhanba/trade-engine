    "Finish":  {"main": [[{"node": "Yanıt Gönder", "type": "main", "index": 0}]]},
    "Status":  {"main": [[{"node": "Yanıt Gönder", "type": "main", "index": 0}]]},
    "Balance": {"main": [[{"node": "Yanıt Gönder", "type": "main", "index": 0}]]}
