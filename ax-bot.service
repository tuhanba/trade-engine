[Unit]
Description=AX Trade Engine - Scalp Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/trade_engine
EnvironmentFile=/root/trade_engine/.env
ExecStart=/root/trade_engine/.venv/bin/python /root/trade_engine/scalp_bot_v3.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
