[Unit]
Description=AX Trade Engine - Scalp Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/trade_engine
EnvironmentFile=-/root/trade_engine/.env
ExecStart=/root/trade_engine/.venv/bin/python /root/trade_engine/scalp_bot.py
Restart=on-failure
RestartSec=10
StartLimitIntervalSec=60
StartLimitBurst=3
StandardOutput=append:/root/trade_engine/logs/ax_bot.log
StandardError=append:/root/trade_engine/logs/ax_bot.log
Environment=PYTHONUNBUFFERED=1
Environment=PYTHONPATH=/root/trade_engine

[Install]
WantedBy=multi-user.target
