{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "tags": ["aurvex", "system"],
  "title": "AurvexAI — Sistem Metrikleri",
  "timezone": "utc",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Kümülatif PnL (USD)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 0 } ] } } },
      "targets": [ { "expr": "total_paper_pnl", "refId": "A" } ]
    },
    {
      "id": 2,
      "title": "Açık Trade Sayısı",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [ { "color": "blue", "value": null } ] } } },
      "targets": [ { "expr": "active_trades_current", "refId": "A" } ]
    },
    {
      "id": 3,
      "title": "WebSocket Gecikmesi (ms)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [ { "expr": "websocket_ping_ms", "refId": "A" } ]
    },
    {
      "id": 4,
      "title": "DB Yazma Gecikmesi (ms)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [ { "expr": "db_write_latency_ms", "refId": "A" } ]
    },
    {
      "id": 5,
      "title": "Açılan İşlem Oranı (5dk)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [ { "expr": "sum(rate(trade_opened_total[5m]))", "refId": "A", "legendFormat": "açılan/sn" } ]
    },
    {
      "id": 6,
      "title": "Kapanan İşlem (sonuç bazlı, 5dk)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [ { "expr": "sum by (result) (rate(trade_closed_total[5m]))", "refId": "A", "legendFormat": "{{result}}" } ]
    },
    {
      "id": 7,
      "title": "Sistem Hataları (modül bazlı, 5dk)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "targets": [ { "expr": "sum by (module) (rate(system_errors_total[5m]))", "refId": "A", "legendFormat": "{{module}}" } ]
    },
    {
      "id": 8,
      "title": "Engine Up (scrape)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "short", "mappings": [
        { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ] } },
      "targets": [ { "expr": "up{job=\"aurvex_engine\"}", "refId": "A" } ]
    }
  ]
}
