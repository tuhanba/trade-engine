<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AURVEX — AI Trade Engine</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#090b11;--surface:#0f1420;--card:#141928;--border:#1e2540;
  --accent:#00e5a0;--accent2:#7c6ffb;--red:#ff4466;--yellow:#f5a623;
  --text:#e2e8f0;--muted:#5a6a8a;--success:#00e5a0;--danger:#ff4466;
}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;padding:0}
/* Header */
.header{background:linear-gradient(135deg,#0f1420 0%,#141928 100%);border-bottom:1px solid var(--border);padding:16px 28px;display:flex;align-items:center;justify-content:space-between}
.logo{font-size:1.4rem;font-weight:800;background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.status-bar{display:flex;gap:16px;align-items:center;font-size:.78rem}
.status-dot{width:8px;height:8px;border-radius:50%;display:inline-block;margin-right:5px}
.dot-ok{background:var(--accent);box-shadow:0 0 8px var(--accent)}
.dot-err{background:var(--red);box-shadow:0 0 8px var(--red)}
.dot-warn{background:var(--yellow)}
.mode-badge{background:#1e2540;border:1px solid var(--border);border-radius:6px;padding:3px 10px;font-weight:600;font-size:.75rem;color:var(--accent2)}
/* Layout */
.main{padding:20px 28px;max-width:1600px;margin:0 auto}
/* Stats Grid */
.stats-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:20px}
.stat{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:16px;position:relative;overflow:hidden;transition:transform .2s}
.stat:hover{transform:translateY(-2px)}
.stat::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),var(--accent2))}
.stat .lbl{font-size:.72rem;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:.05em}
.stat .val{font-size:1.6rem;font-weight:800;margin-top:4px}
.stat .val.pos{color:var(--accent)}
.stat .val.neg{color:var(--red)}
.stat .val.neutral{color:var(--text)}
.stat .sub{font-size:.72rem;color:var(--muted);margin-top:3px}
/* Section */
.section{margin-bottom:20px}
.section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.section-title{font-size:.85rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em}
.badge{padding:2px 8px;border-radius:6px;font-size:.72rem;font-weight:700}
.badge-open{background:#0d2a1e;color:var(--accent);border:1px solid #1a4a32}
.badge-closed{background:#2a0d1e;color:var(--red);border:1px solid #4a1a2a}
.badge-watch{background:#1e1a2a;color:var(--accent2);border:1px solid #2a2040}
.badge-allow{background:#0d2a1e;color:var(--accent)}
.badge-veto{background:#2a0d0d;color:var(--red)}
/* Card */
.card{background:var(--card);border:1px solid var(--border);border-radius:12px;overflow:hidden}
/* Table */
table{width:100%;border-collapse:collapse;font-size:.82rem}
th{padding:10px 14px;text-align:left;color:var(--muted);font-weight:600;font-size:.72rem;text-transform:uppercase;border-bottom:1px solid var(--border);background:var(--surface)}
td{padding:10px 14px;border-bottom:1px solid rgba(30,37,64,.6)}
tr:last-child td{border-bottom:none}
tr:hover td{background:rgba(255,255,255,.02)}
.pos{color:var(--accent)}
.neg{color:var(--red)}
.neutral{color:var(--muted)}
/* Trade row extras */
.symbol{font-weight:700;letter-spacing:.03em}
.side-long{color:var(--accent);font-weight:700}
.side-short{color:var(--red);font-weight:700}
/* TP indicators */
.tp-indicators{display:flex;gap:4px}
.tp-dot{width:8px;height:8px;border-radius:50%;background:var(--border)}
.tp-dot.hit{background:var(--accent)}
/* Live indicator */
.live-pulse{display:inline-flex;align-items:center;gap:6px;font-size:.75rem;color:var(--accent);font-weight:600}
.pulse{width:8px;height:8px;border-radius:50%;background:var(--accent);animation:pulse 1.5s infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.3)}}
/* Ghost section */
.ghost-row{display:flex;gap:12px;flex-wrap:wrap}
.ghost-card{flex:1;min-width:140px;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:14px;text-align:center}
.ghost-card .g-val{font-size:1.3rem;font-weight:800;color:var(--accent2)}
.ghost-card .g-lbl{font-size:.72rem;color:var(--muted);margin-top:3px}
/* Empty state */
.empty{text-align:center;padding:32px;color:var(--muted);font-size:.85rem}
/* Health bar */
.health-items{display:flex;flex-wrap:wrap;gap:10px;padding:14px}
.health-item{display:flex;align-items:center;gap:6px;font-size:.8rem;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:6px 12px}
/* Stream status */
.stream-status{font-size:.72rem;color:var(--muted);display:flex;align-items:center;gap:5px}
/* Responsive */
@media(max-width:768px){.main{padding:12px};.stats-row{grid-template-columns:repeat(2,1fr)}}
=======
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>AURVEX.Ai — Elite Trading Intelligence</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Rajdhani:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<script src="https://cdn.socket.io/4.5.4/socket.io.min.js"></script>
<style>
:root {
  --void:       #000000;
  --notif-success: #059669;
  --notif-error: #B91C1C;
  --notif-info: #00B4FF;
  --bg:         #030508;
  --surface:    #070c12;
  --card:       #0a1018;
  --card2:      #0d1520;
  --border:     rgba(0,180,255,0.10);
  --border-br:  rgba(0,180,255,0.22);

  --cyan:       #00B4FF;
  --cyan-br:    #38CFFF;
  --cyan-dim:   #7DE3FF;
  --cyan-glow:  rgba(0,180,255,0.28);
  --cyan-bg:    rgba(0,180,255,0.06);
  --cyan-line:  rgba(0,180,255,0.22);

  --blue:       #0066CC;
  --blue-br:    #1E90FF;
  --blue-dim:   rgba(0,102,204,0.12);

  --purple:     #7B2FFF;
  --purple-br:  #A855F7;
  --purple-dim: rgba(123,47,255,0.10);

  --red:        #B91C1C;
  --red-br:     #EF4444;
  --red-dim:    rgba(185,28,28,0.10);
  --red-line:   rgba(185,28,28,0.28);

  --green:      #059669;
  --green-br:   #34D399;
  --green-dim:  rgba(5,150,105,0.10);

  --text:       rgba(220,240,255,0.93);
  --text-sec:   rgba(160,200,235,0.60);
  --text-muted: rgba(100,150,190,0.38);

  --orb:  "Orbitron", sans-serif;
  --raj:  "Rajdhani", sans-serif;
  --mono: "JetBrains Mono", monospace;
  --r: 3px; --t: 0.18s ease;
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--void);color:var(--text);font-family:var(--raj);font-size:13px;line-height:1.5;min-height:100vh;overflow-x:hidden}

/* GRID BACKGROUND */
body::before{
  content:'';position:fixed;inset:0;z-index:0;pointer-events:none;
  background-image:
    linear-gradient(rgba(0,180,255,0.018) 1px,transparent 1px),
    linear-gradient(90deg,rgba(0,180,255,0.018) 1px,transparent 1px),
    radial-gradient(ellipse 120% 60% at 50% 0%,rgba(0,100,200,0.08) 0%,transparent 65%),
    radial-gradient(ellipse 60% 40% at 80% 80%,rgba(123,47,255,0.04) 0%,transparent 60%);
  background-size:48px 48px,48px 48px,100% 100%,100% 100%;
}

/* SCAN LINE */
body::after{
  content:'';position:fixed;inset:0;z-index:0;pointer-events:none;
  background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.03) 2px,rgba(0,0,0,0.03) 4px);
}

/* PARTICLES */
.particle{position:fixed;width:1px;height:1px;background:var(--cyan-br);border-radius:50%;animation:float-up linear infinite;pointer-events:none;z-index:0;opacity:0.5}
@keyframes float-up{0%{transform:translateY(105vh);opacity:0}10%{opacity:.4}90%{opacity:.08}100%{transform:translateY(-5vh);opacity:0}}

/* ── HEADER ── */
.hdr{position:sticky;top:0;z-index:200;height:64px;background:rgba(0,3,8,0.97);border-bottom:1px solid var(--cyan-line);display:flex;align-items:center;justify-content:space-between;padding:0;backdrop-filter:blur(24px);box-shadow:0 2px 40px rgba(0,180,255,0.07);overflow:hidden}
.hdr::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(0,180,255,0.15),var(--cyan-br),rgba(0,180,255,0.15),transparent);background-size:200% 100%;animation:shimmer 5s linear infinite}
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}

.hdr-logo-wrap{height:64px;width:72px;min-width:72px;display:flex;align-items:center;justify-content:center;border-right:1px solid rgba(0,180,255,0.15);background:radial-gradient(ellipse at center,rgba(0,180,255,0.05) 0%,transparent 70%);position:relative;flex-shrink:0}
.logo-img{width:52px;height:52px;object-fit:contain;position:relative;z-index:1;filter:drop-shadow(0 0 10px rgba(0,180,255,0.80)) drop-shadow(0 0 25px rgba(0,180,255,0.45)) drop-shadow(0 0 50px rgba(123,47,255,0.30));animation:logo-pulse 4s ease-in-out infinite}
@keyframes logo-pulse{0%,100%{filter:drop-shadow(0 0 10px rgba(0,180,255,0.80)) drop-shadow(0 0 25px rgba(0,180,255,0.45)) drop-shadow(0 0 50px rgba(123,47,255,0.30))}50%{filter:drop-shadow(0 0 18px rgba(0,180,255,1.0)) drop-shadow(0 0 42px rgba(0,180,255,0.65)) drop-shadow(0 0 75px rgba(123,47,255,0.50))}}

.hdr-center{flex:1;padding:0 20px;display:flex;flex-direction:column;justify-content:center;gap:2px}
.hdr-name{font-family:var(--orb);font-size:19px;font-weight:900;letter-spacing:0.16em;background:linear-gradient(135deg,#FFFFFF 0%,#7DE3FF 25%,#38CFFF 55%,#00B4FF 80%,#7B2FFF 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1}
.hdr-tag{font-family:var(--raj);font-size:8.5px;letter-spacing:0.36em;color:var(--text-muted);text-transform:uppercase;font-weight:600}

.hdr-right{display:flex;align-items:center;gap:10px;padding-right:20px;flex-shrink:0}
.pill{font-family:var(--mono);font-size:8.5px;letter-spacing:0.10em;padding:4px 11px;border-radius:var(--r);display:flex;align-items:center;gap:5px}
.pill-live{color:var(--green-br);background:var(--green-dim);border:1px solid rgba(52,211,153,0.22)}
.pill-live::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--green-br);box-shadow:0 0 6px var(--green-br);animation:blink 1.8s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.12}}
.pill-mode{color:var(--cyan-br);background:var(--cyan-bg);border:1px solid var(--cyan-line);font-family:var(--orb);font-size:7.5px;letter-spacing:0.2em}
.hdr-clock{font-family:var(--mono);font-size:10.5px;color:var(--text-muted);min-width:106px;text-align:right}

/* ── LAYOUT ── */
.main{max-width:1440px;margin:0 auto;padding:16px 20px;position:relative;z-index:1}

/* ── STATS GRID ── */
.sg{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:12px}
@media(max-width:860px){.sg{grid-template-columns:repeat(2,1fr)}}
.sc{background:var(--card);border:1px solid var(--border);border-top:2px solid var(--cyan);padding:15px 17px;position:relative;overflow:hidden;border-radius:var(--r);transition:all var(--t)}
.sc::before{content:'';position:absolute;top:0;left:0;right:0;bottom:0;background:linear-gradient(135deg,rgba(0,180,255,0.03) 0%,transparent 60%);pointer-events:none}
.sc::after{content:'';position:absolute;top:0;left:-120%;width:50%;height:100%;background:linear-gradient(90deg,transparent,rgba(0,180,255,0.06),transparent);transition:left .7s ease;pointer-events:none}
.sc:hover::after{left:160%}
.sc:hover{border-top-color:var(--cyan-br);box-shadow:0 8px 35px rgba(0,180,255,0.10);transform:translateY(-2px)}
.sc-label{font-family:var(--orb);font-size:7px;letter-spacing:0.26em;text-transform:uppercase;color:var(--text-muted);margin-bottom:9px}
.sc-val{font-family:var(--mono);font-size:26px;font-weight:700;color:var(--cyan-br);line-height:1;margin-bottom:5px;letter-spacing:-0.02em}
.sc-val.pos{color:var(--green-br);text-shadow:0 0 20px rgba(52,211,153,0.30)}
.sc-val.neg{color:var(--red-br);text-shadow:0 0 20px rgba(239,68,68,0.30)}
.sc-val.warn{color:var(--cyan-br);text-shadow:0 0 18px var(--cyan-glow)}
.sc-sub{font-family:var(--raj);font-size:10.5px;color:var(--text-muted);font-weight:500}
.sc-bar{height:2px;background:rgba(0,180,255,0.06);margin-top:11px;border-radius:2px;overflow:hidden}
.sc-bar-f{height:100%;border-radius:2px;background:linear-gradient(90deg,var(--blue),var(--cyan),var(--cyan-dim));background-size:200% 100%;animation:bar-shine 3s linear infinite;transition:width 1.4s cubic-bezier(.25,1,.5,1)}
@keyframes bar-shine{0%{background-position:200% 0}100%{background-position:-200% 0}}
@keyframes slideIn{0%{transform:translateX(400px);opacity:0}100%{transform:translateX(0);opacity:1}}
@keyframes slideOut{0%{transform:translateX(0);opacity:1}100%{transform:translateX(400px);opacity:0}}
.sc-bar-f.green{background:linear-gradient(90deg,var(--green),var(--green-br));animation:none}

/* ── GRID ── */
.g2{display:grid;grid-template-columns:1.6fr 1fr;gap:12px;margin-bottom:12px}
.g2b{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px}
.g3{display:grid;grid-template-columns:1fr;gap:12px;margin-bottom:12px}
@media(max-width:820px){.g2,.g2b{grid-template-columns:1fr}}

/* ── CARD ── */
.card{background:var(--card);border:1px solid var(--border);padding:16px 18px;border-radius:var(--r);position:relative;overflow:hidden;transition:box-shadow var(--t)}
.card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--cyan-line),var(--cyan-br),var(--cyan-line),transparent);background-size:300% 100%;animation:shimmer 8s linear infinite}
.card:hover{box-shadow:0 6px 40px rgba(0,180,255,0.06)}
.card-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;padding-bottom:10px;border-bottom:1px solid rgba(0,180,255,0.07)}
.card-title{font-family:var(--orb);font-size:8px;letter-spacing:0.24em;text-transform:uppercase;color:var(--cyan-br);font-weight:600;display:flex;align-items:center;gap:8px}
.card-title::before{content:'';display:block;width:2px;height:15px;background:linear-gradient(180deg,var(--cyan-dim),var(--cyan),var(--purple-br));border-radius:2px;box-shadow:0 0 8px var(--cyan-glow)}
.card-meta{font-family:var(--mono);font-size:9.5px;color:var(--text-muted)}

/* ── TRADINGVIEW ── */
.tv-wrap{position:relative;width:100%;border-radius:var(--r);overflow:hidden;background:#050a10}
.tv-controls{display:flex;align-items:center;gap:7px;margin-bottom:11px;flex-wrap:wrap}
.tv-select{background:var(--surface);border:1px solid var(--border);color:var(--cyan-br);font-family:var(--mono);font-size:9.5px;padding:5px 10px;border-radius:var(--r);cursor:pointer;outline:none;transition:all var(--t)}
.tv-select:hover{border-color:var(--cyan-line)}
.tv-select option{background:#0a1018;color:var(--text)}
.tv-btn{background:var(--cyan-bg);border:1px solid var(--cyan-line);color:var(--cyan-br);font-family:var(--mono);font-size:9.5px;padding:4px 11px;border-radius:var(--r);cursor:pointer;transition:all var(--t)}
.tv-btn:hover,.tv-btn.active{background:var(--cyan);color:#000;font-weight:700;box-shadow:0 0 12px var(--cyan-glow)}
.tv-iframe{width:100%;border:none;border-radius:var(--r)}

/* ── PNL CHART ── */
.chart-wrap{height:175px;position:relative}

/* ── PERF METRICS ── */
.perf-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:13px}
.pm{background:var(--surface);border:1px solid var(--border);padding:10px 12px;border-radius:var(--r);transition:all var(--t);position:relative;overflow:hidden}
.pm::after{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(0,180,255,0.12),transparent)}
.pm:hover{border-color:var(--border-br);transform:translateY(-1px)}
.pm-label{font-family:var(--orb);font-size:6.5px;letter-spacing:0.22em;text-transform:uppercase;color:var(--text-muted);margin-bottom:4px}
.pm-val{font-family:var(--mono);font-size:13.5px;font-weight:600;color:var(--cyan)}
.pm-val.pos{color:var(--green-br)}.pm-val.neg{color:var(--red-br)}.pm-val.dim{color:var(--text-muted)}

/* ── SESSION ── */
.session-row{display:grid;grid-template-columns:repeat(3,1fr);gap:6px}
.sess{background:var(--surface);border:1px solid var(--border);border-top:2px solid var(--cyan-line);padding:11px 12px;text-align:center;border-radius:var(--r);transition:all var(--t)}
.sess:hover{border-top-color:var(--cyan-br);transform:translateY(-1px);box-shadow:0 4px 20px rgba(0,180,255,0.07)}
.sess-name{font-family:var(--orb);font-size:6.5px;letter-spacing:0.26em;text-transform:uppercase;color:var(--text-muted);margin-bottom:5px}
.sess-wr{font-family:var(--mono);font-size:21px;font-weight:700;margin-bottom:2px;letter-spacing:-0.02em}
.sess-detail{font-family:var(--raj);font-size:9.5px;color:var(--text-muted);font-weight:500}

/* ── POSITIONS ── */
.pos-list{display:flex;flex-direction:column;gap:9px}
.pos{border:1px solid var(--border);padding:14px 16px;position:relative;overflow:hidden;border-radius:var(--r);transition:all var(--t)}
.pos.long-p{background:linear-gradient(135deg,#040e0a,#061410);border-left:3px solid var(--green-br)}
.pos.short-p{background:linear-gradient(135deg,#0e0404,#140606);border-left:3px solid var(--red-br)}
.pos:hover{transform:translateY(-2px);box-shadow:0 8px 30px rgba(0,0,0,0.4)}
.pos-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:12px}
.pos-sym{font-family:var(--orb);font-size:14px;font-weight:800;color:var(--cyan-dim);letter-spacing:0.06em}
.pos-dir{font-family:var(--mono);font-size:8.5px;letter-spacing:0.14em;font-weight:600;padding:2px 9px;border-radius:var(--r);text-transform:uppercase;margin-top:3px;display:inline-block}
.pos-dir.long{color:var(--green-br);background:var(--green-dim);border:1px solid rgba(52,211,153,0.22)}
.pos-dir.short{color:var(--red-br);background:var(--red-dim);border:1px solid var(--red-line)}
.pos-pnl-val{font-family:var(--mono);font-size:22px;font-weight:800;letter-spacing:-0.02em;line-height:1}
.pos-pnl-pct{font-family:var(--raj);font-size:10.5px;color:var(--text-muted);margin-top:2px}
.pos-levels{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:10px}
.pl-lbl{font-family:var(--orb);font-size:6.5px;letter-spacing:0.16em;text-transform:uppercase;color:var(--text-muted);margin-bottom:3px}
.pl-val{font-family:var(--mono);font-size:10.5px;font-weight:500}
.pl-val.entry{color:var(--cyan-br)}.pl-val.stop{color:var(--red-br)}.pl-val.target{color:var(--green-br)}.pl-val.rr{color:var(--cyan-dim)}
.pos-bar-bg{height:2px;background:rgba(255,255,255,0.04);margin-bottom:6px;border-radius:2px}
.pos-bar-fill{height:100%;border-radius:2px;transition:width .8s ease}
.pos-bar-fill.long{background:linear-gradient(90deg,var(--green),var(--green-br));box-shadow:0 0 6px rgba(52,211,153,0.28)}
.pos-bar-fill.short{background:linear-gradient(90deg,var(--red),var(--red-br));box-shadow:0 0 6px rgba(239,68,68,0.28)}
.pos-foot{display:flex;justify-content:space-between;font-family:var(--mono);font-size:9.5px;color:var(--text-muted)}
.empty{text-align:center;padding:32px;font-family:var(--orb);font-size:8.5px;letter-spacing:0.22em;color:var(--text-muted);text-transform:uppercase}

/* ── FEED ── */
.feed-wrap{max-height:220px;overflow-y:auto;display:flex;flex-direction:column;gap:5px}
.feed-wrap::-webkit-scrollbar{width:2px}
.feed-wrap::-webkit-scrollbar-thumb{background:var(--cyan-line);border-radius:2px}
.feed-item{display:flex;align-items:center;gap:9px;padding:6px 10px;background:var(--surface);border:1px solid var(--border);border-radius:var(--r);font-family:var(--mono);font-size:9.5px;transition:all var(--t);animation:slideIn .3s ease}
@keyframes slideIn{from{opacity:0;transform:translateX(-8px)}to{opacity:1;transform:translateX(0)}}
.feed-item:hover{border-color:var(--cyan-line)}
.feed-time{color:var(--text-muted);min-width:40px;font-size:8.5px}
.feed-dot{width:5px;height:5px;border-radius:50%;flex-shrink:0}
.feed-dot.open{background:var(--green-br);box-shadow:0 0 5px var(--green-br)}
.feed-dot.close-win{background:var(--cyan-br);box-shadow:0 0 5px var(--cyan-br)}
.feed-dot.close-loss{background:var(--red-br);box-shadow:0 0 5px var(--red-br)}
.feed-dot.reject{background:var(--text-muted)}
.feed-text{flex:1;color:var(--text-sec)}
.feed-text b{color:var(--text)}
.feed-pnl{font-size:9.5px;font-weight:600}

/* ── AI PARAMS ── */
.param-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:11px}
.param{background:var(--surface);border:1px solid var(--border);padding:10px 12px;border-radius:var(--r);transition:all var(--t)}
.param:hover{border-color:var(--border-br);transform:translateY(-1px)}
.param-k{font-family:var(--orb);font-size:6.5px;letter-spacing:0.22em;text-transform:uppercase;color:var(--text-muted);margin-bottom:4px}
.param-v{font-family:var(--mono);font-size:16px;font-weight:700;color:var(--cyan-br)}
.ai-box{background:linear-gradient(135deg,rgba(0,180,255,0.07),rgba(0,180,255,0.02));border:1px solid var(--cyan-line);border-left:3px solid var(--cyan-br);padding:11px 14px;font-family:var(--mono);font-size:10.5px;color:var(--cyan);border-radius:0 var(--r) var(--r) 0;box-shadow:inset 0 0 20px rgba(0,180,255,0.04)}

/* ── AX CHAT ── */
.ax-wrap{display:flex;flex-direction:column;height:100%}
.ax-messages{flex:1;max-height:200px;overflow-y:auto;display:flex;flex-direction:column;gap:7px;margin-bottom:11px;padding-right:4px}
.ax-messages::-webkit-scrollbar{width:2px}
.ax-messages::-webkit-scrollbar-thumb{background:var(--cyan-line)}
.ax-msg{padding:8px 11px;border-radius:var(--r);font-family:var(--mono);font-size:9.5px;line-height:1.5;max-width:90%;animation:slideIn .3s ease}
.ax-msg.user{background:var(--cyan-bg);border:1px solid var(--cyan-line);color:var(--cyan-dim);align-self:flex-end;text-align:right}
.ax-msg.bot{background:var(--surface);border:1px solid var(--border);border-left:2px solid var(--cyan-br);color:var(--text);align-self:flex-start}
.ax-msg.bot::before{content:"AX  ";color:var(--cyan-br);font-weight:700}
.ax-input-row{display:flex;gap:7px}
.ax-input{flex:1;background:var(--surface);border:1px solid var(--border);color:var(--text);font-family:var(--mono);font-size:9.5px;padding:7px 11px;border-radius:var(--r);outline:none;transition:all var(--t)}
.ax-input:focus{border-color:var(--cyan-line);box-shadow:0 0 12px var(--cyan-bg)}
.ax-input::placeholder{color:var(--text-muted)}
.ax-send{background:linear-gradient(135deg,var(--blue),var(--cyan));border:none;color:#000;font-family:var(--orb);font-size:8.5px;letter-spacing:0.1em;padding:7px 13px;border-radius:var(--r);cursor:pointer;font-weight:700;transition:all var(--t)}
.ax-send:hover{background:linear-gradient(135deg,var(--cyan),var(--cyan-br));box-shadow:0 0 16px var(--cyan-glow)}
.ax-dot{width:6px;height:6px;border-radius:50%;background:var(--green-br);animation:blink 2s infinite;box-shadow:0 0 5px var(--green-br)}

/* ── HIST TABLE ── */
.hist-table{width:100%;border-collapse:collapse}
.hist-table th{font-family:var(--orb);font-size:7px;letter-spacing:0.26em;text-transform:uppercase;color:var(--text-muted);font-weight:500;text-align:left;padding:8px 10px;border-bottom:1px solid rgba(0,180,255,0.10)}
.hist-table td{padding:8px 10px;border-bottom:1px solid rgba(0,180,255,0.04);font-family:var(--mono);font-size:10.5px;color:var(--text-sec);vertical-align:middle;transition:all var(--t)}
.hist-table tr:hover td{background:rgba(0,180,255,0.025);color:var(--text)}
.hist-table tr:last-child td{border-bottom:none}
.td-sym{font-family:var(--orb);font-size:11.5px;font-weight:700;color:var(--cyan-dim);letter-spacing:0.06em}
.badge{font-family:var(--mono);font-size:7.5px;letter-spacing:0.12em;font-weight:600;padding:2px 8px;text-transform:uppercase;border-radius:var(--r)}
.b-long{color:var(--green-br);background:var(--green-dim);border:1px solid rgba(52,211,153,0.22)}
.b-short{color:var(--red-br);background:var(--red-dim);border:1px solid var(--red-line)}
.b-win{color:var(--cyan-br);background:var(--cyan-bg);border:1px solid var(--cyan-line);box-shadow:0 0 6px var(--cyan-glow)}
.b-loss{color:var(--red-br);background:var(--red-dim);border:1px solid var(--red-line)}
.pos-c{color:var(--green-br)}.neg-c{color:var(--red-br)}.gld-c{color:var(--cyan-br)}.dim-c{color:var(--text-muted)}
.dur{font-family:var(--raj);font-size:9.5px;font-weight:500;color:var(--text-muted);background:rgba(0,180,255,0.04);padding:2px 7px;border-radius:var(--r)}

/* ── PAGINATION ── */
.pager{display:flex;align-items:center;justify-content:center;gap:4px;margin-top:14px;padding-top:12px;border-top:1px solid rgba(0,180,255,0.07)}
.pb{width:28px;height:28px;background:var(--surface);border:1px solid var(--border);color:var(--text-muted);font-family:var(--mono);font-size:9.5px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all var(--t);border-radius:var(--r)}
.pb:hover{border-color:var(--cyan-line);color:var(--cyan-br);background:var(--cyan-bg)}
.pb.active{background:var(--cyan);border-color:var(--cyan);color:#000;font-weight:700;box-shadow:0 0 14px var(--cyan-glow)}
.pb:disabled{opacity:.2;cursor:not-allowed}
.pinfo{font-family:var(--mono);font-size:9.5px;color:var(--text-muted);padding:0 7px}

/* ── AX STATUS PANEL ── */
.ax-status-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:10px}
@media(max-width:860px){.ax-status-grid{grid-template-columns:repeat(2,1fr)}}
.axs{background:var(--surface);border:1px solid var(--border);padding:11px 13px;border-radius:var(--r);position:relative;overflow:hidden;transition:all var(--t)}
.axs::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(0,180,255,0.15),transparent)}
.axs:hover{border-color:var(--border-br);transform:translateY(-1px)}
.axs-label{font-family:var(--orb);font-size:6.5px;letter-spacing:0.24em;text-transform:uppercase;color:var(--text-muted);margin-bottom:6px}
.axs-val{font-family:var(--mono);font-size:20px;font-weight:700;color:var(--cyan-br);line-height:1;margin-bottom:3px}
.axs-val.pos{color:var(--green-br)}.axs-val.neg{color:var(--red-br)}.axs-val.warn{color:var(--cyan-br)}
.axs-sub{font-family:var(--raj);font-size:10px;color:var(--text-muted)}
.cb-active{border-color:rgba(239,68,68,0.35)!important;background:rgba(185,28,28,0.07)!important}

/* ── SIGNAL STATS ── */
.sig-row{display:flex;gap:8px;flex-wrap:wrap}
.sig-stat{display:flex;flex-direction:column;align-items:center;background:var(--surface);border:1px solid var(--border);padding:9px 14px;border-radius:var(--r);min-width:55px;transition:all var(--t)}
.sig-stat:hover{border-color:var(--border-br)}
.sig-stat-val{font-family:var(--mono);font-size:20px;font-weight:700;line-height:1;margin-bottom:3px}
.sig-allow{color:var(--cyan-br);text-shadow:0 0 12px var(--cyan-glow)}
.sig-watch{color:var(--purple-br)}
.sig-stat-lbl{font-family:var(--orb);font-size:6.5px;letter-spacing:0.20em;text-transform:uppercase;color:var(--text-muted)}

/* ── CALENDAR ── */
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px}
.cal-wday{font-family:var(--orb);font-size:6.5px;letter-spacing:0.18em;text-transform:uppercase;color:var(--text-muted);text-align:center;padding:4px 0}
.cal-day{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:5px 4px;min-height:40px;display:flex;flex-direction:column;align-items:center;justify-content:center;transition:all var(--t);cursor:default}
.cal-day:hover{border-color:var(--border-br)}
.cal-day.empty{background:transparent;border-color:transparent}
.cal-day.pos{background:rgba(5,150,105,0.12);border-color:rgba(52,211,153,0.18)}
.cal-day.neg{background:rgba(185,28,28,0.10);border-color:rgba(239,68,68,0.18)}
.cal-day.today{border-color:var(--cyan-line);box-shadow:0 0 10px var(--cyan-glow)}
.cal-date{font-family:var(--mono);font-size:8.5px;color:var(--text-muted);margin-bottom:2px}
.cal-pnl{font-family:var(--mono);font-size:9px;font-weight:600}
.cal-legend{display:flex;gap:14px;margin-top:10px;font-family:var(--raj);font-size:10px;color:var(--text-muted)}
.cal-legend-dot{display:inline-block;width:8px;height:8px;border-radius:2px;margin-right:4px;vertical-align:middle}

/* ── WEEKLY TABLE ── */
.weekly-table{width:100%;border-collapse:collapse}
.weekly-table th{font-family:var(--orb);font-size:7px;letter-spacing:0.22em;text-transform:uppercase;color:var(--text-muted);text-align:left;padding:7px 9px;border-bottom:1px solid rgba(0,180,255,0.08)}
.weekly-table td{padding:7px 9px;border-bottom:1px solid rgba(0,180,255,0.04);font-family:var(--mono);font-size:10.5px;color:var(--text-sec)}
.weekly-table tr:hover td{background:rgba(0,180,255,0.02)}
.weekly-table tr:last-child td{border-bottom:none}

/* ── COIN PROFILES ── */
.cp-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:7px}
.cp{background:var(--surface);border:1px solid var(--border);padding:11px 13px;border-radius:var(--r);transition:all var(--t);position:relative;overflow:hidden}
.cp::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(0,180,255,0.10),transparent)}
.cp:hover{border-color:var(--border-br);transform:translateY(-1px);box-shadow:0 4px 20px rgba(0,180,255,0.06)}
.cp-sym{font-family:var(--orb);font-size:11px;font-weight:700;color:var(--cyan-dim);letter-spacing:0.06em;margin-bottom:6px}
.cp-wr{font-family:var(--mono);font-size:16px;font-weight:700;margin-bottom:2px}
.cp-detail{font-family:var(--raj);font-size:9.5px;color:var(--text-muted)}
.cp-bar{height:2px;background:rgba(0,180,255,0.06);margin-top:7px;border-radius:2px;overflow:hidden}
.cp-bar-f{height:100%;border-radius:2px;transition:width 1s ease}
.cp-bar-f.good{background:linear-gradient(90deg,var(--green),var(--green-br))}
.cp-bar-f.bad{background:linear-gradient(90deg,var(--red),var(--red-br))}
.cp-bar-f.mid{background:linear-gradient(90deg,var(--blue),var(--cyan))}

/* ── FOOTER ── */
.foot{border-top:1px solid rgba(0,180,255,0.07);margin-top:20px;padding:14px 22px;display:flex;justify-content:space-between;align-items:center}
.foot-l{font-family:var(--orb);font-size:7.5px;letter-spacing:0.18em;color:var(--text-muted);text-transform:uppercase}
.foot-l span{background:linear-gradient(90deg,var(--cyan),var(--cyan-br));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.foot-r{font-family:var(--mono);font-size:9.5px;color:var(--text-muted)}

/* ── SCROLLBAR ── */
::-webkit-scrollbar{width:3px}::-webkit-scrollbar-track{background:var(--void)}::-webkit-scrollbar-thumb{background:var(--cyan-line);border-radius:2px}

/* ── ANIMATIONS ── */
@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.card{animation:fadeUp .30s ease both}
.sc{animation:fadeUp .24s ease both}
.sc:nth-child(1){animation-delay:.00s}.sc:nth-child(2){animation-delay:.06s}.sc:nth-child(3){animation-delay:.12s}.sc:nth-child(4){animation-delay:.18s}

/* ── GLOW EFFECTS ── */
.glow-cyan{box-shadow:0 0 20px rgba(0,180,255,0.15),0 0 60px rgba(0,180,255,0.05)}
.glow-green{box-shadow:0 0 20px rgba(52,211,153,0.15)}
.glow-red{box-shadow:0 0 20px rgba(239,68,68,0.15)}
