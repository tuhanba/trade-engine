};
const fmtDate = s => s ? s.replace('T',' ').substring(0,16)+'Z' : '—';

function renderHealth(h) {
  if (!h) return;
  $('mode-badge').textContent = (h.execution_mode||'PAPER').toUpperCase();
  const items = [
    {label:'DB', ok: h.db_connected, text: h.db_connected?'OK':'ERR'},
    {label:'Bot', ok: h.bot_alive, text: h.bot_alive?'ALIVE':'OFFLINE'},
    {label:'Telegram', ok: h.telegram_configured, text: h.telegram_configured?'OK':'OFF'},
    {label:'Mode', ok: true, text: h.execution_mode||'paper'},
    {label:'Heartbeat', ok: !!h.last_heartbeat, text: h.last_heartbeat ? fmtDate(h.last_heartbeat) : '—'},
  ];
  $('health-items').innerHTML = items.map(i =>
    `<div class="health-item">
      <span class="status-dot ${i.ok?'dot-ok':'dot-err'}"></span>
      <span style="color:var(--muted);font-size:.72rem">${i.label}:</span>
      <strong style="font-size:.78rem">${i.text}</strong>
    </div>`
  ).join('');
  if(h.server_time) $('server-time').textContent = fmtDate(h.server_time);
}

function renderStats(s) {
  if (!s) return;
  const balance = Number(s.balance||0);
  const rpnl = Number(s.realized_pnl||0);
  const upnl = Number(s.unrealized_pnl||0);
  const total = Number(s.total_pnl||0);
  const today = Number(s.today_pnl||0);

  $('s-balance').textContent = '$' + fmt(balance);
  $('s-total-pnl').innerHTML = fmtPnl(total);
  $('s-today-pnl').innerHTML = fmtPnl(today);
  $('s-rpnl').innerHTML = fmtPnl(rpnl);
  $('s-upnl').innerHTML = fmtPnl(upnl);
  $('s-open').textContent = s.open_trades||0;
  $('s-closed').textContent = s.closed_trades||0;
  $('s-wr').textContent = (s.winrate||0) + '%';

  // Ghost
  $('g-total').textContent = s.ghost_tp_hits!=null ? (Number(s.ghost_tp_hits)+Number(s.ghost_sl_hits||0)) : '—';
  $('g-tp').textContent = s.ghost_tp_hits ?? '—';
  $('g-sl').textContent = s.ghost_sl_hits ?? '—';
  $('g-wr').textContent = s.ghost_winrate != null ? s.ghost_winrate+'%' : '—';
  const total_g = (Number(s.ghost_tp_hits||0)+Number(s.ghost_sl_hits||0));
  $('g-pending').textContent = (Number(s.total_trades||0)) > 0 ?
    Math.max(0, (s.total_trades||0) - total_g) : '—';
}

function renderLive(live) {
  const tb = $('live-tbody');
  if (!live || !live.length) {
    tb.innerHTML = `<tr><td colspan="11" class="empty">Açık pozisyon yok</td></tr>`;
    return;
  }
  tb.innerHTML = live.map(t => {
    const sideClass = t.side==='LONG' ? 'side-long' : 'side-short';
    const tpDots = `<div class="tp-indicators">
      <div class="tp-dot ${t.tp1_hit?'hit':''}" title="TP1"></div>
      <div class="tp-dot ${t.tp2_hit?'hit':''}" title="TP2"></div>
    </div>`;
    const state = [
      t.breakeven_set ? '<span style="color:var(--accent);font-size:.7rem">BE✓</span>' : '',
      t.trailing_active ? '<span style="color:var(--accent2);font-size:.7rem">TRAIL</span>' : '',
    ].filter(Boolean).join(' ');
    return `<tr>
      <td class="symbol">${t.symbol}</td>
      <td class="${sideClass}">${t.side}</td>
      <td>${fmt(t.entry_price,4)}</td>
      <td>${fmt(t.current_price,4)}</td>
      <td>${fmt(t.stop_loss,4)}</td>
      <td>${fmt(t.tp1,4)} / ${fmt(t.tp2,4)} / ${fmt(t.tp3,4)}</td>
      <td>${t.leverage}x</td>
      <td>${fmtPnl(t.unrealized_pnl)}</td>
      <td>${fmtPnl(t.total_pnl)}</td>
      <td>${fmt(t.remaining_qty_pct,0)}%</td>
      <td style="display:flex;gap:6px;align-items:center">${tpDots}${state}</td>
    </tr>`;
  }).join('');
}

function renderTrades(trades) {
  const tb = $('trades-tbody');
  if (!trades || !trades.length) {
    tb.innerHTML = `<tr><td colspan="9" class="empty">Trade yok</td></tr>`;
    return;
  }
  tb.innerHTML = trades.slice(0,25).map(t => {
    const badge = t.status==='OPEN' ? 'badge-open' : 'badge-closed';
    const sideClass = t.side==='LONG' ? 'side-long' : 'side-short';
    return `<tr>
      <td style="color:var(--muted)">#${t.id}</td>
      <td class="symbol">${t.symbol}</td>
      <td class="${sideClass}">${t.side}</td>
      <td>${fmt(t.entry_price,4)}</td>
      <td>${t.exit_price ? fmt(t.exit_price,4) : '—'}</td>
      <td>${fmtPnl(t.realized_pnl)}</td>
      <td><span class="badge ${badge}">${t.status}</span></td>
      <td style="color:var(--muted);font-size:.75rem">${t.close_reason||'—'}</td>
      <td style="color:var(--muted);font-size:.72rem">${fmtDate(t.opened_at)}</td>
    </tr>`;
  }).join('');
}

function renderSignals(signals) {
  const tb = $('signals-tbody');
  if (!signals || !signals.length) {
    tb.innerHTML = `<tr><td colspan="7" class="empty">Sinyal yok</td></tr>`;
    return;
  }
  const badgeMap = {
    'ALLOW':'badge-allow','VETO':'badge-veto',
    'WATCH':'badge-watch','SKIPPED_BY_RISK':'badge-watch','SKIPPED_BY_FILTER':'badge-watch'
  };
  tb.innerHTML = signals.slice(0,20).map(s => {
    const dec = s.decision||'';
    const badge = badgeMap[dec]||'badge-watch';
    const sideClass = s.side==='LONG' ? 'side-long' : 'side-short';
    const statusBadge = s.status==='TP_HIT'
      ? '<span class="badge badge-allow">TP✓</span>'
      : s.status==='SL_HIT'
      ? '<span class="badge badge-closed">SL✗</span>'
      : `<span style="color:var(--muted);font-size:.72rem">${s.status||'NEW'}</span>`;
    return `<tr>
      <td class="symbol">${s.symbol}</td>
      <td class="${sideClass}">${s.side}</td>
      <td>${fmt(s.entry_price,4)}</td>
      <td>${fmt(s.score,1)}</td>
      <td><span class="badge ${badge}">${dec}</span></td>
      <td>${statusBadge}</td>
      <td style="color:var(--muted);font-size:.72rem;max-width:200px;overflow:hidden;text-overflow:ellipsis">${s.reason||'—'}</td>
    </tr>`;
  }).join('');
}

// ── SSE Stream ──────────────────────────────────────────────────────
let evtSource = null;
let reconnectTimer = null;

function connect() {
  if (evtSource) { evtSource.close(); }
  evtSource = new EventSource('/stream');

  evtSource.onopen = () => {
    $('stream-dot').className = 'status-dot dot-ok';
    $('stream-label').textContent = 'Real-time';
    clearTimeout(reconnectTimer);
  };

  evtSource.onmessage = (e) => {
    try {
      const d = JSON.parse(e.data);
      if (d.error) { console.warn('Stream error:', d.error); return; }
      renderHealth(d.health);
      renderStats(d.stats);
      renderLive(d.live);
      renderTrades(d.trades);
      renderSignals(d.signals);
    } catch(err) { console.error('Parse error:', err); }
  };

  evtSource.onerror = () => {
    $('stream-dot').className = 'status-dot dot-err';
    $('stream-label').textContent = 'Bağlantı kesildi — yeniden bağlanıyor…';
    evtSource.close();
    reconnectTimer = setTimeout(connect, 5000);
  };
}

// Fallback: SSE yoksa polling
function startPolling() {
  async function poll() {
    try {
      const [h,s,l,t,sig] = await Promise.all([
        fetch('/api/health').then(r=>r.json()).then(d=>d.ok?d.data:null).catch(()=>null),
        fetch('/api/stats').then(r=>r.json()).then(d=>d.ok?d.data:null).catch(()=>null),
        fetch('/api/live').then(r=>r.json()).then(d=>d.ok?d.data:null).catch(()=>null),
        fetch('/api/trades').then(r=>r.json()).then(d=>d.ok?d.data:null).catch(()=>null),
        fetch('/api/signals').then(r=>r.json()).then(d=>d.ok?d.data:null).catch(()=>null),
      ]);
      renderHealth(h); renderStats(s); renderLive(l); renderTrades(t); renderSignals(sig);
      $('stream-dot').className='status-dot dot-ok';
      $('stream-label').textContent='Polling 15s';
    } catch(e) {
      $('stream-dot').className='status-dot dot-err';
    }
  }
  poll();
  setInterval(poll, 15000);
}

// Önce SSE dene, başarısız olursa polling
try {
  connect();
} catch(e) {
  startPolling();
}
