<script>
const BASE = "/";t chart=null,curPage=1;const PER=10;
const f=(v,d=4)=>v==null?"—":Number(v).toFixed(d);
const fp=(v,d=3)=>v==null?"—":(Number(v)>=0?"+":"")+Number(v).toFixed(d)+"$";
const fc=(v)=>{const n=Number(v);return n>0?"pos-c":n<0?"neg-c":"dim-c"};

// Clock
function tick(){const s=new Date().toUTCString().split(" ")[4]+" UTC";document.getElementById("clock").textContent=s;document.getElementById("footTime").textContent=s}
setInterval(tick,1000);tick();

// TradingView
let tvSymbol="BINANCE:BTCUSDT",tvTF="5";
function loadTV(){
  tvSymbol=document.getElementById("tvSymbol").value;
  const base=encodeURIComponent(tvSymbol);
  const ovr=encodeURIComponent(JSON.stringify({
    "mainSeriesProperties.candleStyle.upColor":"#34D399",
    "mainSeriesProperties.candleStyle.downColor":"#EF4444",
    "mainSeriesProperties.candleStyle.borderUpColor":"#34D399",
    "mainSeriesProperties.candleStyle.borderDownColor":"#EF4444",
    "mainSeriesProperties.candleStyle.wickUpColor":"#34D399",
    "mainSeriesProperties.candleStyle.wickDownColor":"#EF4444",
    "paneProperties.background":"#050a10",
    "paneProperties.vertGridProperties.color":"#0d1520",
    "paneProperties.horzGridProperties.color":"#0d1520"
  }));
  const studies=encodeURIComponent("RSI@tv-basicstudiesMACD@tv-basicstudiesBB@tv-basicstudies");
  document.getElementById("tvChart").src=
    "https://s.tradingview.com/widgetembed/?frameElementId=tvChart"+
    "&symbol="+base+"&interval="+tvTF+
    "&hidesidetoolbar=0&hidetoptoolbar=0&symboledit=0&saveimage=0"+
    "&toolbarbg=050a10&studies="+studies+
    "&theme=dark&style=1&timezone=Europe%2FIstanbul"+
    "&withdateranges=1&showpopupbutton=1"+
    "&overrides="+ovr;
}
function setTF(btn,tf){
  document.querySelectorAll(".tv-btn").forEach(b=>b.classList.remove("active"));
  btn.classList.add("active");tvTF=tf;loadTV();
