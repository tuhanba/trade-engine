    const wrap=document.getElementById("posList");
    if(!pos.length){wrap.innerHTML="<div class='empty'>— Acik Pozisyon Yok —</div>";return}
    wrap.innerHTML=pos.map(p=>{
      const isL=(p.direction||"").toUpperCase()==="LONG",pnl=p.unrealized_pnl||0,bar=Math.min(Math.abs(p.sl_distance_pct||0),100);
      const tgt=p.active_target||p.tp1?"TP"+(p.active_target||"1"):"—";
      const tp1v=p.tp1||p.tp||0,tp2v=p.tp2||0,tp3v=p.tp3||0;
      return "<div class='pos "+(isL?"long-p":"short-p")+"'><div class='pos-top'><div><div class='pos-sym'>"+p.symbol+"</div><span class='pos-dir "+(isL?"long":"short")+"'>"+p.direction+" x"+(p.leverage||"—")+"</span></div><div class='pos-pnl'><div class='pos-pnl-val "+(pnl>=0?"pos-c":"neg-c")+"'>"+fp(pnl)+"</div><div class='pos-pnl-pct'>"+(pnl>=0?"+":"")+f(p.unrealized_pct,2)+"%</div></div></div><div class='pos-levels'><div><div class='pl-lbl'>Entry</div><div class='pl-val entry'>"+f(p.entry,5)+"</div></div><div><div class='pl-lbl'>Stop</div><div class='pl-val stop'>"+f(p.sl,4)+"</div></div><div><div class='pl-lbl'>TP1</div><div class='pl-val target'>"+f(tp1v,4)+"</div></div><div><div class='pl-lbl'>TP2</div><div class='pl-val target'>"+f(tp2v,4)+"</div></div></div><div class='pos-levels'><div><div class='pl-lbl'>TP3</div><div class='pl-val target'>"+f(tp3v,4)+"</div></div><div><div class='pl-lbl'>Hedef</div><div class='pl-val rr'>"+tgt+"</div></div><div><div class='pl-lbl'>Kalan</div><div class='pl-val'>"+f(p.remaining_qty,4)+"</div></div><div><div class='pl-lbl'>Süre</div><div class='pl-val'>"+((p.duration_str||"—"))+"</div></div></div><div class='pos-bar-bg'><div class='pos-bar-fill "+(isL?"long":"short")+"' style='width:"+bar+"%'></div></div><div class='pos-foot'><span>Mark: "+f(p.current_price,5)+"</span><span>Risk: $"+f(p.risk_usd,2)+"</span><span>SL: "+f(p.sl_distance_pct,1)+"%</span></div></div>";
    }).join("");
  }catch(e){console.error(e)}
}

// HISTORY
let knownTrades={};
let currentTab = 'history';
function switchTab(tab){
  currentTab = tab;
  document.getElementById('tabHistory').classList.toggle('active', tab==='history');
  document.getElementById('tabArchive').classList.toggle('active', tab==='archive');
  document.getElementById('viewHistory').style.display = tab==='history' ? 'block' : 'none';
  document.getElementById('viewArchive').style.display = tab==='archive' ? 'block' : 'none';
  if(tab==='history') loadHistory(1);
  else loadArchive(1);
}

async function loadHistory(page=1){
  try{
    curPage=page;
    const j=await(await fetch(BASE+"/api/trades?page="+page+"&per_page="+PER)).json();if(!j.ok)return;
    const trades=j.data||[],pag=j; // API yapısı gereği pagination verileri root'ta
    document.getElementById("histCount").textContent=(pag.total_count||0)+" islem";
    const tb=document.getElementById("histBody");
    if(!trades.length){tb.innerHTML="<tr><td colspan='8' style='text-align:center;color:var(--text-muted);padding:28px;font-family:var(--orb);letter-spacing:.16em;font-size:8.5px'>KAYIT YOK</td></tr>";renderPager(pag, 'history');return}
    tb.innerHTML=trades.map(t=>{
      const isL=(t.direction||"").toUpperCase()==="LONG",pnl=t.net_pnl||0,st=(t.status||"").toUpperCase(),win=st==="WIN"||(st==="MANUAL"&&pnl>0),dur=t.duration_str||(t.duration_min?Math.round(t.duration_min)+"dk":"—");
      return "<tr><td class='td-sym'>"+(t.symbol||"—")+"</td><td><span class='badge "+(isL?"b-long":"b-short")+"'>"+(t.direction||"—")+"</span></td><td>"+f(t.entry,5)+"</td><td>"+f(t.exit_price,5)+"</td><td class='"+(pnl>=0?"pos-c":"neg-c")+"'>"+fp(pnl)+"</td><td class='gld-c'>"+f(t.r_multiple,2)+"R</td><td><span class='dur'>"+dur+"</span></td><td><span class='badge "+(win?"b-win":"b-loss")+"'>"+st+"</span></td></tr>";
    }).join("");renderPager(pag, 'history');
  }catch(e){console.error(e)}
}

async function loadArchive(page=1){
  try{
    const j=await(await fetch(BASE+"/api/signal_archive?page="+page+"&limit=10")).json();if(!j.ok)return;
    const signals=j.data||[],pag=j;
    document.getElementById("archiveCount").textContent=(pag.total_count||0)+" sinyal";
    const tb=document.getElementById("archiveBody");
    if(!signals.length){tb.innerHTML="<tr><td colspan='8' style='text-align:center;color:var(--text-muted);padding:28px;font-family:var(--orb);letter-spacing:.16em;font-size:8.5px'>KAYIT YOK</td></tr>";renderPager(pag, 'archive');return}
    tb.innerHTML=signals.map(s=>{
      const mfe=s.mfe||0, mae=s.mae||0, win=s.would_have_won===1;
      const date=s.created_at ? s.created_at.substring(5,16) : "—";
      return "<tr><td class='td-sym'>"+(s.symbol||"—")+"</td><td><span class='badge b-long'>"+(s.setup_quality||"—")+"</span></td><td>"+f(s.final_score,1)+"</td><td><span class='badge "+(s.decision==='ALLOW'?'b-win':'b-loss')+"'>"+(s.decision||"—")+"</span></td><td class='pos-c'>"+f(mfe,2)+"</td><td class='neg-c'>"+f(mae,2)+"</td><td><span class='badge "+(win?'b-win':'b-loss')+"'>"+(win?'WIN':'LOSS')+"</span></td><td><span class='dur'>"+date+"</span></td></tr>";
    }).join("");renderPager(pag, 'archive');
  }catch(e){console.error(e)}
}

function renderPager(pag, type){
  const wrapId = type === 'history' ? 'pager' : 'archivePager';
  const loadFn = type === 'history' ? 'loadHistory' : 'loadArchive';
  const wrap=document.getElementById(wrapId),tot=pag.total_pages||1,cur=pag.page||1;
  if(tot<=1){wrap.innerHTML="";return}
  let h="<button class='pb' "+(cur<=1?"disabled":"")+" onclick='"+loadFn+"("+(cur-1)+")'>&#8249;</button>";
  for(let i=1;i<=tot;i++){if(i===1||i===tot||Math.abs(i-cur)<=2)h+="<button class='pb "+(i===cur?"active":"")+"' onclick='"+loadFn+"("+i+")'>"+i+"</button>";else if(Math.abs(i-cur)===3)h+="<span class='pinfo'>&#8230;</span>"}
  h+="<button class='pb' "+(cur>=tot?"disabled":"")+" onclick='"+loadFn+"("+(cur+1)+")'>&#8250;</button><span class='pinfo'>"+cur+" / "+tot+"</span>";
  wrap.innerHTML=h;
}

// AX STATUS
async function loadAxStatus(){
  try{
    const results=await Promise.allSettled([
      fetch(BASE+"/api/ax_status").then(r=>r.json()),
      fetch(BASE+"/api/scalp_signal_stats").then(r=>r.json()),
      fetch(BASE+"/api/health").then(r=>r.json()),
    ]);
    const jsAx  = results[0].status==="fulfilled"?results[0].value:null;
    const jsSig = results[1].status==="fulfilled"?results[1].value:null;
    const jsHlth= results[2].status==="fulfilled"?results[2].value:null;
    if(jsAx&&jsAx.ok){
      const d=jsAx.data;
      document.getElementById("axBalance").textContent="$"+f(d.balance,2);
      const ot=document.getElementById("axOpenTrades");
      ot.textContent=d.open_trades;ot.className="axs-val"+(d.open_trades>0?" warn":"");
      const tp=document.getElementById("axTodayPnl");
      tp.textContent=(d.today_pnl>=0?"+":"")+f(d.today_pnl,2)+"$";
      tp.className="axs-val"+(d.today_pnl>0?" pos":d.today_pnl<0?" neg":"");
      document.getElementById("axTodayTrades").textContent=d.today_trades+" trade bugun";
      const cbCard=document.getElementById("axCbCard");
      const cbEl=document.getElementById("axCb");const cbSub=document.getElementById("axCbSub");
      if(d.circuit_breaker_active){cbCard.classList.add("cb-active");cbEl.textContent="AKTİF";cbEl.className="axs-val neg";cbSub.textContent="Bekleniyor..."}
      else{cbCard.classList.remove("cb-active");cbEl.textContent="KAPALI";cbEl.className="axs-val pos";cbSub.textContent="Normal"}
      document.getElementById("axMode").textContent=(d.mode||"paper").toUpperCase();
      const modeEl=document.getElementById("mode-indicator");
      if(modeEl){const safe=d.paper_safety_status==="SECURE";modeEl.textContent=safe?"PAPER / DRY-RUN":"⚠ "+((d.execution_mode||"paper").toUpperCase());modeEl.style.color=safe?"":"var(--red-br)";}
      const pausedEl=document.getElementById("axPaused");
      pausedEl.textContent=d.paused?"DURAKLATILDI":"AKTİF";pausedEl.style.color=d.paused?"var(--cyan-br)":"var(--green-br)";
      document.getElementById("axStatusMeta").textContent=new Date().toLocaleTimeString("tr-TR",{timeZone:"UTC"})+" UTC";
    }
    if(jsSig&&jsSig.ok){
      const s=jsSig.data;
      document.getElementById("sigS").textContent=s["S"]||0;
      document.getElementById("sigAPlus").textContent=s["A+"]||0;
      document.getElementById("sigA").textContent=s["A"]||0;
      document.getElementById("sigB").textContent=s["B"]||0;
      document.getElementById("sigTotal").textContent=s.total||0;
    }
  }catch(e){console.error("axStatus",e)}
}

// CALENDAR
async function loadCalendar(){
  try{
    const j=await(await fetch(BASE+"/api/daily_pnl")).json();
    if(!j.ok)return;
    const days=j.data||{};
    const now=new Date();const year=now.getFullYear();const month=now.getMonth();
    const firstDay=new Date(year,month,1).getDay();
    const daysInMonth=new Date(year,month+1,0).getDate();
    const today=now.getDate();
    const monthNames=["Ocak","Subat","Mart","Nisan","Mayis","Haziran","Temmuz","Agustos","Eylul","Ekim","Kasim","Aralik"];
    document.getElementById("calMeta").textContent=monthNames[month]+" "+year;
    const grid=document.getElementById("calGrid");grid.innerHTML="";
    const startOffset=(firstDay+6)%7;
    for(let i=0;i<startOffset;i++){const d=document.createElement("div");d.className="cal-day empty";grid.appendChild(d)}
    for(let d=1;d<=daysInMonth;d++){
      const dateStr=year+"-"+(String(month+1).padStart(2,"0"))+"-"+(String(d).padStart(2,"0"));
      const pnl=days[dateStr];
      const div=document.createElement("div");
      div.className="cal-day"+(d===today?" today":"")+(pnl!=null?(pnl>0?" pos":" neg"):"");
      div.innerHTML="<div class='cal-date'>"+d+"</div><div class='cal-pnl' style='color:"+(pnl==null?"var(--text-muted)":pnl>0?"var(--green-br)":"var(--red-br)")+"'>"+(pnl!=null?(pnl>0?"+":"")+pnl.toFixed(2)+"$":"")+"</div>";
      grid.appendChild(div);
    }
  }catch(e){console.error(e)}
}

// WEEKLY
async function loadWeekly(){
  try{
    const j=await(await fetch(BASE+"/api/weekly")).json();
    if(!j.ok)return;
    const weeks=j.data||[];
    const tb=document.getElementById("weeklyBody");
    if(!weeks.length){tb.innerHTML="<tr><td colspan='6' style='text-align:center;color:var(--text-muted);padding:22px;font-family:var(--orb);font-size:8.5px;letter-spacing:0.16em'>KAYIT YOK</td></tr>";return}
    tb.innerHTML=weeks.map(w=>{
      const pnl=w.net_pnl||0;const wrW=w.win_rate<=1?(w.win_rate*100):w.win_rate;
      return "<tr><td style='color:var(--text-muted)'>"+(w.week_start||'\u2014')+"</td><td>"+(w.trade_count||0)+"</td><td style='color:"+(wrW>=45?"var(--green-br)":wrW>=35?"var(--cyan-br)":"var(--red-br)")+"'>"+f(wrW,1)+"%</td><td class='"+(pnl>=0?"pos-c":"neg-c")+"'>"+fp(pnl)+"</td><td class='pos-c'>"+fp(w.best_day||0)+"</td><td class='neg-c'>"+fp(w.worst_day||0)+"</td></tr>";
    }).join("");
  }catch(e){console.error(e)}
}

// COIN PROFILES
async function loadCoinProfiles(){
  try{
    const j=await(await fetch(BASE+"/api/coin_profiles")).json();
    if(!j.ok)return;
    const profiles=j.data||[];
    document.getElementById("cpMeta").textContent=profiles.length+" coin";
    const grid=document.getElementById("cpGrid");
    if(!profiles.length){grid.innerHTML="<div class='cp'><div class='cp-sym' style='color:var(--text-muted)'>Veri yok</div></div>";return}
    grid.innerHTML=profiles.map(p=>{
      const wr=p.win_rate||0;const pnl=p.total_pnl||0;
      const cls=wr>=50?"good":wr>=35?"mid":"bad";
      return "<div class='cp'><div class='cp-sym'>"+p.symbol.replace("USDT","")+"</div><div class='cp-wr' style='color:"+(wr>=50?"var(--green-br)":wr>=35?"var(--cyan-br)":"var(--red-br)")+"'>"+wr.toFixed(0)+"%</div><div class='cp-detail'>"+p.total+" trade · "+fp(pnl)+"</div><div class='cp-bar'><div class='cp-bar-f "+cls+"' style='width:"+Math.min(wr,100)+"%'></div></div></div>";
    }).join("");
  }catch(e){console.error(e)}
}

// INIT & REFRESH
async function refreshAll(){
  await Promise.allSettled([loadStats(),loadChart(),loadPositions(),loadHistory(curPage),loadAxStatus(),loadCalendar(),loadWeekly(),loadCoinProfiles()]);
}
refreshAll();
setInterval(()=>{loadPositions();loadAxStatus();},8000);
setInterval(()=>{loadStats();loadChart();loadHistory(curPage);loadWeekly();},30000);
setInterval(()=>{loadCoinProfiles();loadCalendar();},120000);
