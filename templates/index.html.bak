// CANLI AKIS
const feedItems=[];
function addFeedItem(time,type,text,pnl){
  const wrap=document.getElementById("feedWrap");
  if(feedItems.length===0)wrap.innerHTML="";
  const div=document.createElement("div");div.className="feed-item";
  const pnlHtml=pnl?"<span class='feed-pnl "+(pnl>0?"pos-c":"neg-c")+"'>"+fp(pnl)+"</span>":"";
  div.innerHTML="<span class='feed-time'>"+time+"</span><div class='feed-dot "+type+"'></div><span class='feed-text'>"+text+"</span>"+pnlHtml;
  wrap.insertBefore(div,wrap.firstChild);
  feedItems.unshift({time,type,text,pnl});
  if(feedItems.length>50){wrap.removeChild(wrap.lastChild);feedItems.pop()}
  document.getElementById("feedCount").textContent=feedItems.length+" olay";
}

